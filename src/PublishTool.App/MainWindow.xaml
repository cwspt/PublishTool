<Window x:Class="PublishTool.App.MainWindow" Icon="pack://application:,,,/favicon.ico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PublishTool - 项目编译发布工具" Width="1020" Height="660"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#1677FF"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF4D4F"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
    
        <Style x:Key="ToolbarButton" TargetType="Button">            <Setter Property="Background" Value="Transparent"/>            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>            <Setter Property="BorderThickness" Value="1"/>            <Setter Property="Padding" Value="8,4"/>            <Setter Property="FontSize" Value="13"/>            <Setter Property="Cursor" Value="Hand"/>            <Setter Property="Template">                <Setter.Value>                    <ControlTemplate TargetType="Button">                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>                        </Border>                    </ControlTemplate>                </Setter.Value>            </Setter>            <Style.Triggers>                <Trigger Property="IsMouseOver" Value="True">                    <Setter Property="BorderBrush" Value="#1677FF"/>                    <Setter Property="Background" Value="#EBF3FF"/>                </Trigger>                <Trigger Property="IsEnabled" Value="False">                    <Setter Property="Opacity" Value="0.4"/>                </Trigger>            </Style.Triggers>        </Style>
    
        <Style TargetType="ListViewItem">            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>            <Style.Triggers>                <Trigger Property="ItemsControl.AlternationIndex" Value="1">                    <Setter Property="Background" Value="#F7F9FC"/>                </Trigger>                <Trigger Property="IsMouseOver" Value="True">                    <Setter Property="Background" Value="#E6F4FF"/>                </Trigger>                <Trigger Property="IsSelected" Value="True">                    <Setter Property="Background" Value="#D6EBFF"/>                    <Setter Property="FontWeight" Value="Bold"/>                </Trigger>            </Style.Triggers>        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- Toolbar Row 1 -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Button Style="{StaticResource ToolbarButton}" Content="+ 添加项目" Width="100" Click="AddProject_Click" Margin="0,0,6,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="✎ 编辑" Width="66" Click="EditProject_Click" Margin="0,0,6,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="✕ 删除" Width="66" Click="DeleteProject_Click" Margin="0,0,6,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="📂 项目目录" Width="88" Click="OpenFolder_Click" Margin="0,0,12,0"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,8,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="📥 导入配置" Width="88" Click="ImportConfig_Click" Margin="0,0,6,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="📤 导出配置" Width="88" Click="ExportConfig_Click"/>
        </StackPanel>

        <!-- Toolbar Row 2 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="配置:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="CmbConfig" Width="90" SelectedIndex="0">
                <ComboBoxItem Content="Debug"/>
                <ComboBoxItem Content="Release"/>
            </ComboBox>
            <Button Style="{StaticResource ToolbarButton}" Content="▶ 编译" Width="66" Click="Build_Click" Margin="6,0,4,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="📁 产物" Width="66" Click="OpenBuildOutput_Click" ToolTip="打开编译产物目录" Margin="0,0,4,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="▶ 启动" Width="66" Click="Run_Click" ToolTip="启动编译产物的可执行文件" Margin="0,0,12,0"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,6,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="📦 发布" Width="66" Click="Publish_Click" Margin="0,0,4,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="📁 发布目录" Width="80" Click="OpenPublishDir_Click" ToolTip="打开发布输出目录" Margin="0,0,12,0"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,6,0"/>
            <Button Style="{StaticResource ToolbarButton}" x:Name="BtnStop" Content="⏹ 停止" Width="66" Click="Stop_Click"
                    ToolTip="终止当前任务" IsEnabled="False" Foreground="Red" FontWeight="Bold"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0,4,0"/>
            <ComboBox x:Name="CmbCustomScript" Width="130" ToolTip="选择自定义脚本" Margin="0,0,4,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="▶ 执行" Width="60" Click="RunCustomScript_Click"
                    ToolTip="执行选中的自定义脚本" Margin="0,0,6,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="🗑 清空日志" Width="80" Click="ClearLog_Click" ToolTip="清空日志输出" Margin="4,0,0,0" Opacity="0.7"/>
        </StackPanel>

        <!-- Toolbar Row 3: Project groups -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="组:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="CmbGroup" Width="150" SelectionChanged="CmbGroup_SelectionChanged"/>
            <Button Style="{StaticResource ToolbarButton}" x:Name="BtnGroupBuild" Content="▶ 组脚本" Width="72" Click="BuildGroup_Click"
                    ToolTip="执行组内配置的编译脚本" Margin="4,0,4,0"
                    IsEnabled="False"/>
            <Button Style="{StaticResource ToolbarButton}" x:Name="BtnGroupPublish" Content="📦 发布组" Width="80" Click="PublishGroup_Click"
                    ToolTip="按顺序发布组内所有项目" Margin="4,0,6,0"/>
            <Button Style="{StaticResource ToolbarButton}" Content="⚙" Width="30" Click="ManageGroups_Click"
                    ToolTip="管理项目组" Margin="0,0,0,0"/>
        </StackPanel>

        <!-- Project List -->
        <ListView Grid.Row="3" x:Name="LstProjects" SelectionMode="Single"
                  SelectionChanged="LstProjects_SelectionChanged" Margin="0,0,0,8">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="编辑项目" Click="EditProject_Click"/>
                    <MenuItem Header="删除项目" Click="DeleteProject_Click"/>
                    <Separator/>
                    <MenuItem Header="打开项目目录" Click="OpenProjectDir_Click"/>
                    <MenuItem Header="打开产物目录" Click="OpenOutputDir_Click"/>
                    <MenuItem Header="打开发布目录" Click="OpenPublishDir_Click"/>
                    <Separator/>
                    <MenuItem Header="编译 (Debug)" Click="ContextBuildDebug_Click"/>
                    <MenuItem Header="编译 (Release)" Click="ContextBuildRelease_Click"/>
                    <MenuItem Header="发布" Click="ContextPublish_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="状态" Width="130" DisplayMemberBinding="{Binding StatusText}"/>
                    <GridViewColumn Header="名称" Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding IconPath}" Width="20" Height="20"
                                           Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="类型" Width="90" DisplayMemberBinding="{Binding Type}"/>
                    <GridViewColumn Header="项目路径" Width="300" DisplayMemberBinding="{Binding ProjectPath}"/>
                    <GridViewColumn Header="发布目录" Width="240" DisplayMemberBinding="{Binding PublishDir}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock Grid.Row="3" x:Name="TxtEmptyHint" Text="还没有项目，点击「+ 添加项目」开始吧"
                   FontSize="16" Foreground="Gray" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Visibility="Collapsed"
                   IsHitTestVisible="False"/>

        <StatusBar Grid.Row="4" Margin="0,0,0,4">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="就绪"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtProjectCount"/>
            </StatusBarItem>
        </StatusBar>

        <GridSplitter Grid.Row="5" Height="4" HorizontalAlignment="Stretch" Background="LightGray" Margin="0,4"/>
        <TextBox Grid.Row="6" x:Name="TxtOutput" IsReadOnly="True" FontFamily="Consolas"
                 TextWrapping="Wrap" HorizontalScrollBarVisibility="Disabled"
                 FontSize="12" VerticalScrollBarVisibility="Auto" Background="#1e1e1e"
                 Foreground="#d4d4d4" Margin="0,4,0,0"/>
    </Grid>
</Window>
