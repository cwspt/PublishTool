<Window x:Class="PublishTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="pack://application:,,,/favicon.ico"
        Title="PublishTool - 项目编译发布工具" Width="1080" Height="720"
        MinWidth="900" MinHeight="600" WindowStartupLocation="CenterScreen"
        Background="#F5F7FA" FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#DCE2EA"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryToolbarButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E40AF"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FEF2F2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="6,7"/>
            <Setter Property="BorderBrush" Value="#E8EDF3"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFBFC"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F6FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1E3A8A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,9"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="180"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="180" MinHeight="100"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="5" Padding="12,10" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <WrapPanel>
                    <Button Content="+ 添加项目" Style="{StaticResource PrimaryToolbarButton}" Width="104" Click="AddProject_Click"/>
                    <Button Content="编辑" Style="{StaticResource ToolbarButton}" Width="68" Click="EditProject_Click"/>
                    <Button Content="删除" Style="{StaticResource DangerButton}" Width="68" Click="DeleteProject_Click"/>
                    <Button Content="项目目录" Style="{StaticResource ToolbarButton}" Width="88" Click="OpenFolder_Click" Margin="0,0,18,6"/>
                    <Button Content="导入配置" Style="{StaticResource ToolbarButton}" Width="88" Click="ImportConfig_Click"/>
                    <Button Content="导出配置" Style="{StaticResource ToolbarButton}" Width="88" Click="ExportConfig_Click"/>
                </WrapPanel>

                <WrapPanel Grid.Row="1" Margin="0,2,0,0" VerticalAlignment="Center">
                    <TextBlock Text="构建配置" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
                    <ComboBox x:Name="CmbConfig" Width="100" SelectedIndex="0" Margin="0,0,8,6">
                        <ComboBoxItem Content="Debug"/>
                        <ComboBoxItem Content="Release"/>
                    </ComboBox>
                    <Button Content="编译" Style="{StaticResource PrimaryToolbarButton}" Width="68" Click="Build_Click"/>
                    <Button Content="产物" Style="{StaticResource ToolbarButton}" Width="64" Click="OpenBuildOutput_Click" ToolTip="打开编译产物目录"/>
                    <Button Content="启动" Style="{StaticResource ToolbarButton}" Width="64" Click="Run_Click" ToolTip="启动编译产物的可执行文件" Margin="0,0,18,6"/>
                    <Button Content="发布" Style="{StaticResource PrimaryToolbarButton}" Width="68" Click="Publish_Click"/>
                    <Button Content="发布目录" Style="{StaticResource ToolbarButton}" Width="84" Click="OpenPublishDir_Click" ToolTip="打开发布输出目录" Margin="0,0,18,6"/>
                    <Button x:Name="BtnStop" Content="停止" Style="{StaticResource DangerButton}" Width="64" Click="Stop_Click"
                            ToolTip="终止当前任务" IsEnabled="False"/>
                    <ComboBox x:Name="CmbCustomScript" Width="150" ToolTip="选择自定义脚本" Margin="0,0,6,6"/>
                    <Button Content="执行脚本" Style="{StaticResource ToolbarButton}" Width="80" Click="RunCustomScript_Click" ToolTip="执行选中的自定义脚本"/>
                    <Button Content="清空日志" Style="{StaticResource ToolbarButton}" Width="80" Click="ClearLog_Click" ToolTip="清空日志输出"/>
                </WrapPanel>

                <WrapPanel Grid.Row="2" Margin="0,2,0,0" VerticalAlignment="Center">
                    <TextBlock Text="项目组" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,6,6"/>
                    <ComboBox x:Name="CmbGroup" Width="170" SelectionChanged="CmbGroup_SelectionChanged" Margin="0,0,6,6"/>
                    <Button x:Name="BtnGroupBuild" Content="执行组脚本" Style="{StaticResource ToolbarButton}" Width="92" Click="BuildGroup_Click"
                            ToolTip="执行组内配置的编译脚本" IsEnabled="False"/>
                    <Button x:Name="BtnGroupPublish" Content="发布组" Style="{StaticResource ToolbarButton}" Width="76" Click="PublishGroup_Click"
                            ToolTip="按顺序发布组内所有项目"/>
                    <Button Content="管理项目组" Style="{StaticResource ToolbarButton}" Width="96" Click="ManageGroups_Click" ToolTip="管理项目组"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5">
                <ListView x:Name="LstProjects" SelectionMode="Single" AlternationCount="2" Background="Transparent"
                          SelectionChanged="LstProjects_SelectionChanged">
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="编辑项目" Click="EditProject_Click"/>
                            <MenuItem Header="删除项目" Click="DeleteProject_Click"/>
                            <Separator/>
                            <MenuItem Header="打开项目目录" Click="OpenProjectDir_Click"/>
                            <MenuItem Header="打开产物目录" Click="OpenOutputDir_Click"/>
                            <MenuItem Header="打开发布目录" Click="OpenPublishDir_Click"/>
                            <Separator/>
                            <MenuItem Header="编译 (Debug)" Click="ContextBuildDebug_Click"/>
                            <MenuItem Header="编译 (Release)" Click="ContextBuildRelease_Click"/>
                            <MenuItem Header="发布" Click="ContextPublish_Click"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="状态" Width="120" DisplayMemberBinding="{Binding StatusText}"/>
                            <GridViewColumn Header="名称" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding IconSource}" Width="20" Height="20" Stretch="Uniform"
                                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="类型" Width="100" DisplayMemberBinding="{Binding Type}"/>
                            <GridViewColumn Header="项目路径" Width="330" DisplayMemberBinding="{Binding ProjectPath}"/>
                            <GridViewColumn Header="发布目录" Width="250" DisplayMemberBinding="{Binding PublishDir}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
            <StackPanel x:Name="TxtEmptyHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Collapsed" IsHitTestVisible="False">
                <TextBlock Text="暂无项目" FontSize="17" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Center"/>
                <TextBlock Text="点击上方“添加项目”开始管理编译与发布任务" Margin="0,6,0,0"
                           Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="4" Padding="10,6" Margin="0,10,0,8">
            <Grid>
                <TextBlock x:Name="TxtStatus" Text="就绪" Foreground="#1E3A8A" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtProjectCount" Foreground="#475569" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="#CBD5E1" ShowsPreview="True"/>
        <Border Grid.Row="4" Background="#111827" CornerRadius="5" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="运行日志" Foreground="#CBD5E1" FontWeight="SemiBold" Margin="12,0" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" x:Name="TxtOutput" IsReadOnly="True" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                         TextWrapping="Wrap" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                         Background="#111827" Foreground="#E5E7EB" BorderThickness="0" Padding="12,4,12,10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
