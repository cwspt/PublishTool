<Window x:Class="PublishTool.App.Views.ProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="项目编辑" Width="560" Height="650"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        TextOptions.TextFormattingMode="Display"
        Background="#F0F2F5">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#1677FF"/>
        <SolidColorBrush x:Key="BorderLight" Color="#D9D9D9"/>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button" x:Key="DialogButton">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4096FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Name -->
            <TextBlock Text="项目名称" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" x:Name="TxtName" Height="26" Margin="0,0,0,14"/>

            <!-- Path -->
            <TextBlock Grid.Row="2" Text="项目文件路径 (.csproj / 项目目录)" FontWeight="Bold" Margin="0,0,0,4"/>
            <Grid Grid.Row="3" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtPath" Height="26"/>
                <Button Grid.Column="1" Content="浏览..." Width="70" Margin="8,0,0,0" Click="BrowsePath_Click"/>
            </Grid>

            <!-- Type -->
            <TextBlock Grid.Row="4" Text="项目类型" FontWeight="Bold" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="5" x:Name="CmbType" Height="26" Margin="0,0,0,14">
                <ComboBoxItem Content="控制台 (Console)"/>
                <ComboBoxItem Content="WinForms"/>
                <ComboBoxItem Content="WPF"/>
                <ComboBoxItem Content="Android"/>
                <ComboBoxItem Content="Vue"/>
                <ComboBoxItem Content="Blazor WebAssembly"/>
                <ComboBoxItem Content="Blazor Server"/>
            </ComboBox>

            <!-- Publish dir -->
            <TextBlock Grid.Row="6" Text="发布目标目录" FontWeight="Bold" Margin="0,0,0,4"/>
            <Grid Grid.Row="7" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtPublishDir" Height="26"/>
                <Button Grid.Column="1" Content="浏览..." Width="70" Margin="8,0,0,0" Click="BrowsePublishDir_Click"/>
            </Grid>

            <!-- Custom build/publish scripts -->
            <Expander Grid.Row="8" Header="自定义编译/发布脚本（可选）" Margin="0,8,0,0" IsExpanded="False" FontWeight="Bold">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Debug 编译脚本" FontWeight="Normal" Margin="0,0,0,2"/>
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtDebugScript" Height="26" ToolTip="例如: dotnet build -c Debug --no-restore"/>
                        <Button Grid.Column="1" Content="浏览..." Width="70" Margin="8,0,0,0" Click="BrowseDebugScript_Click"/>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="Release 编译脚本" FontWeight="Normal" Margin="0,0,0,2"/>
                    <Grid Grid.Row="3" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtReleaseScript" Height="26" ToolTip="例如: dotnet build -c Release --no-restore"/>
                        <Button Grid.Column="1" Content="浏览..." Width="70" Margin="8,0,0,0" Click="BrowseReleaseScript_Click"/>
                    </Grid>

                    <TextBlock Grid.Row="4" Text="发布脚本" FontWeight="Normal" Margin="0,0,0,2"/>
                    <Grid Grid.Row="5" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtPublishScript" Height="26" ToolTip="例如: dotnet publish -c Release -o D:\output --no-restore"/>
                        <Button Grid.Column="1" Content="浏览..." Width="70" Margin="8,0,0,0" Click="BrowsePublishScript_Click"/>
                    </Grid>
                </Grid>
            </Expander>

            <!-- Custom user scripts -->
            <Expander Grid.Row="9" Header="自定义脚本" Margin="0,8,0,0" IsExpanded="False" FontWeight="Bold">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Content="+ 添加脚本" Width="80" Click="AddCustomScript_Click" Margin="0,0,0,6"/>
                    <ScrollViewer Grid.Row="1" MaxHeight="180" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="IcsCustomScripts">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding Name}" Height="26" ToolTip="脚本名称"/>
                                        <TextBox Grid.Column="1" Text="{Binding Path}" Height="26" Margin="6,0,0,0" ToolTip="脚本文件路径"/>
                                        <Button Grid.Column="2" Content="浏览..." Width="70" Margin="6,0,0,0" Click="BrowseCustomScript_Click" Tag="{Binding}"/>
                                        <Button Grid.Column="3" Content="✕" Width="28" Margin="4,0,0,0" Click="RemoveCustomScript_Click" Tag="{Binding}" Foreground="Red" FontWeight="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Expander>

            <!-- Buttons -->
            <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="确定" Width="80" Height="28" Click="Ok_Click" Style="{StaticResource DialogButton}" Margin="0,0,10,0"/>
                <Button Content="取消" Width="80" Height="28" Click="Cancel_Click" Style="{StaticResource DialogButton}" Background="#F5F5F5" Foreground="#333333"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>