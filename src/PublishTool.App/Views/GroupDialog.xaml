<Window x:Class="PublishTool.App.Views.GroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理项目组" Width="700" Height="700"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        MinWidth="560" MinHeight="460" Background="#F5F7FA" FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#DCE2EA"/>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#1D4ED8"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="border" Property="Background" Value="#1E40AF"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0ECFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DBEAFE"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1D4ED8"/>
                                <Setter Property="Foreground" Value="#1E3A8A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox"><Setter Property="Height" Value="30"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Padding" Value="7,0"/></Style>
        <Style TargetType="ListViewItem"><Setter Property="Padding" Value="5"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/></Style>
        <Style TargetType="GridViewColumnHeader"><Setter Property="Background" Value="#F8FAFC"/><Setter Property="Padding" Value="7"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="170"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="项目组" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                <TextBlock Text="配置项目执行顺序和可选的组编译脚本" Foreground="#64748B" Margin="0,3,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="新建" Style="{StaticResource SecondaryButton}" Width="64" Click="AddGroup_Click" Margin="0,0,6,0"/>
                <Button Content="删除" Style="{StaticResource SecondaryButton}" Width="64" Click="DeleteGroup_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,8,0,10">
            <ListBox x:Name="LstGroups" Height="62" BorderThickness="0" Padding="4" SelectionChanged="LstGroups_SelectionChanged"/>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions><ColumnDefinition Width="82"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="组名称" VerticalAlignment="Center" Foreground="#475569"/>
            <TextBox Grid.Column="1" x:Name="TxtGroupName"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="82"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="编译脚本" VerticalAlignment="Center" Foreground="#475569"/>
            <TextBox Grid.Column="1" x:Name="TxtBuildScript" ToolTip="可选，设置后可在主界面执行组脚本"/>
            <Button Grid.Column="2" Content="浏览" Style="{StaticResource SecondaryButton}" Width="64" Margin="8,0,0,0" Click="BrowseBuildScript_Click"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,5">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="组成员（按执行顺序）" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="上移" Style="{StaticResource SecondaryButton}" Width="58" Click="MoveUp_Click" ToolTip="上移" Margin="0,0,5,0"/>
                <Button Content="下移" Style="{StaticResource SecondaryButton}" Width="58" Click="MoveDown_Click" ToolTip="下移"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="5">
            <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <ListView x:Name="LstMembers" SelectionMode="Single" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="序号" Width="48" DisplayMemberBinding="{Binding Order}"/>
                            <GridViewColumn Header="项目名称" Width="180" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="类型" Width="88" DisplayMemberBinding="{Binding Type}"/>
                            <GridViewColumn Header="发布目录" Width="280" DisplayMemberBinding="{Binding PublishDir}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
            <TextBlock x:Name="TxtEmptyHint" Text="从下方勾选项目添加到当前项目组"
                       Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False"/>
        </Grid>

        <Expander Grid.Row="6" Header="添加项目到组" IsExpanded="True" Margin="0,8,0,0" FontWeight="SemiBold" Foreground="#334155">
            <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,5,0,0">
                <ListView x:Name="LstAvailable" Height="110" SelectionMode="Single" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="36">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate><CheckBox IsChecked="{Binding IsInGroup}" Click="MemberCheck_Click" HorizontalAlignment="Center"/></DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="项目名称" Width="180" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="类型" Width="88" DisplayMemberBinding="{Binding Type}"/>
                            <GridViewColumn Header="发布目录" Width="280" DisplayMemberBinding="{Binding PublishDir}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Expander>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" Width="82" Click="Cancel_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="确定" Width="82" Click="Ok_Click" Style="{StaticResource DialogButton}"/>
        </StackPanel>
    </Grid>
</Window>
