<Window x:Class="PublishTool.App.Views.GroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理项目组" Width="640" Height="560"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        MinWidth="500" MinHeight="400">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Group list -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="项目组列表" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="+ 新建" Width="60" Click="AddGroup_Click" Margin="0,0,6,0"/>
                <Button Content="✕ 删除" Width="60" Click="DeleteGroup_Click"/>
            </StackPanel>
        </Grid>

        <!-- Row 1: Groups ListBox -->
        <ListBox Grid.Row="1" x:Name="LstGroups" Height="90" Margin="0,4,0,12"
                 SelectionChanged="LstGroups_SelectionChanged"/>

        <!-- Row 2: Group name -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="组名称:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
            <TextBox Grid.Column="1" x:Name="TxtGroupName" Height="26"/>
        </Grid>

        <!-- Row 3: Build script -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="编译脚本:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
            <TextBox Grid.Column="1" x:Name="TxtBuildScript" Height="26"
                     ToolTip="可选，设置后在主界面可点击「编译组」按钮"/>
            <Button Grid.Column="2" Content="浏览..." Width="70" Margin="8,0,0,0"
                    Click="BrowseBuildScript_Click"/>
        </Grid>

        <!-- Row 4: Ordered members header -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="组成员（按执行顺序）" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,2">
                <Button Content="↑" Width="28" Click="MoveUp_Click" ToolTip="上移"/>
                <Button Content="↓" Width="28" Click="MoveDown_Click" Margin="2,0,0,0" ToolTip="下移"/>
            </StackPanel>
        </Grid>

        <!-- Row 5: Ordered members ListView -->
        <ListView Grid.Row="5" x:Name="LstMembers" MaxHeight="160" SelectionMode="Single" Margin="0,2,0,8">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="序号" Width="48" DisplayMemberBinding="{Binding Order}"/>
                    <GridViewColumn Header="项目名称" Width="180" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="类型" Width="80" DisplayMemberBinding="{Binding Type}"/>
                    <GridViewColumn Header="发布目录" Width="240" DisplayMemberBinding="{Binding PublishDir}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock Grid.Row="5" x:Name="TxtEmptyHint" Text="从下方勾选项目添加到组中"
                   FontSize="13" Foreground="Gray" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Visibility="Collapsed"/>

        <!-- Row 6: Available projects -->
        <Expander Grid.Row="6" Header="添加项目到组" IsExpanded="True" Margin="0,4,0,0">
            <ListView x:Name="LstAvailable" MaxHeight="160" SelectionMode="Single">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="" Width="28">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsInGroup}" Click="MemberCheck_Click"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="项目名称" Width="180" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="类型" Width="80" DisplayMemberBinding="{Binding Type}"/>
                        <GridViewColumn Header="发布目录" Width="240" DisplayMemberBinding="{Binding PublishDir}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Expander>

        <!-- Row 7: Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Width="80" Height="28" Click="Ok_Click" Margin="0,0,10,0"/>
            <Button Content="取消" Width="80" Height="28" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>